# Server configuration
PORT=3500
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/continental?schema=public"

# Auth
JWT_SECRET="replace_with_a_strong_random_secret"
JWT_EXPIRES_IN=7d

# Optional S3 configuration (required if using upload endpoints)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace_with_access_key
AWS_SECRET_ACCESS_KEY=replace_with_secret_key
AWS_BUCKET_NAME=replace_with_bucket_name

# Legacy aliases used by current codebase (optional if AWS_* are set)
region=ap-south-1
access_key=replace_with_access_key
secret_key=replace_with_secret_key
bucket_name=replace_with_bucket_name
