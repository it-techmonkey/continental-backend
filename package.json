{
    "name": "continental-backend",
    "version": "1.0.0",
    "description": "Node.js TypeScript Express Backend Server",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "clean": "rimraf dist",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:studio": "prisma studio",
        "db:seed": "tsx prisma/seed.ts"
    },
    "keywords": [
        "nodejs",
        "typescript",
        "express",
        "backend"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "express": "^4.19.2",
        "cors": "^2.8.5",
        "helmet": "^7.1.0",
        "dotenv": "^16.4.5",
        "@prisma/client": "^5.16.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.17",
        "@types/node": "^20.14.10",
        "typescript": "^5.5.3",
        "tsx": "^4.16.5",
        "rimraf": "^5.0.10",
        "prisma": "^5.16.1"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}